import sys

l = int(input("Enter the length of rectangle: "))
if l <= 0:
    print("Invalid length. Must be greater than 0.")
    sys.exit()

b = int(input("Enter the breadth of rectangle: "))
if b <= 0:
    print("Invalid breadth. Must be greater than 0.")
    sys.exit()

# If it gets here, both inputs are 100% valid
perimeter = 2 * (l + b)
area = l * b

print("Area:", area)
print("Perimeter:", perimeter)
